library(dplyr)
library(ggplot2)
library(ggpubr)
library(reshape2)
library('dendextend')
setwd("/home/au687642/OneDrive/Documents/Postdoc/MutationalScanning/CurationResults/")
testis_samples <- c("ob2v","ob003h", "stephan","carl","mbewe", "samson")
sperm_samples <- c("tsaed", "da1", "la4")
human <- c("ob2v","ob003h")
chimp <- c("stephan","carl")
gorilla <- c("mbewe", "samson")
chrlengthsP <- read.table("t_to_t.tsv", sep = "\t", header = T)
chr_lengths_human <- chrlengthsP$Seq.length[1:22]
names(chr_lengths_human) <- chrlengthsP$UCSC.style.name[1:22]
tmp <- read.table("gorGor4.txt.tsv", sep = "\t", header = T)
chr_lengths_gorilla <- tmp$Seq.length[1:23]
names(chr_lengths_gorilla) <- tmp$UCSC.style.name[1:23]
tmp <- read.table("panTro6.tsv", sep = "\t", header = T)
chr_lengths_chimp <- tmp$Seq.length[1:23]
names(chr_lengths_chimp) <- tmp$UCSC.style.name[1:23]
GC_names <- c()
fn <- 1
data <- list()
data_bins <- list()
data_bins_GC <- c()
data_bins_CO <- c()
for (f in list.files(path = "GC/")){
GC_names <- c(GC_names, strsplit(f, "_")[[1]][1])
if (strsplit(f, "_")[[1]][1] %in% human){
chr_len <- chr_lengths_human
} else if (strsplit(f, "_")[[1]][1] %in% chimp){
chr_len <- chr_lengths_chimp
chr_len <- c(chr_len[1],chr_len[2]+chr_len[3], chr_len[4:length(chr_len)])
} else if (strsplit(f, "_")[[1]][1] %in% gorilla){
chr_len <- chr_lengths_gorilla
chr_len <- c(chr_len[1],chr_len[2]+chr_len[3], chr_len[4:length(chr_len)])
} else if (strsplit(f, "_")[[1]][1] %in% sperm_samples){
chr_len <- chr_lengths_human
} else {
chr_len <- NA
}
if (strsplit(f, "_")[[1]][1] == "tsaed"){
tmp_gc <- read.csv(paste0("GC/",strsplit(f, "_")[[1]][1], "_germline_reads.csv"))
tmp_gc$chr <- tmp_gc$chromosome
tmp_gc$right_jump_snp_ref <- tmp_gc$break_position
} else {
tmp_gc <- read.csv(paste0("GC/",f), sep = "\t")
}
tmp_gc$chrID <- as.numeric(unlist(strsplit(tmp_gc$chr, "chr"))[-which(unlist(strsplit(tmp_gc$chr, "chr"))=="")])
tmp_gc <- na.omit(tmp_gc) #removes chr 2A and 2B
if (sum(tmp_gc$chrID==2)>0){
tmp_gc <- tmp_gc[-which(tmp_gc$chrID==2),]
}
tmp_gc <- tmp_gc[order(tmp_gc$chrID),]
for (i in 1:nrow(tmp_gc)){
if (tmp_gc$chrID[i]>1){
tmp_gc$right_jump_snp_ref[i] <- as.numeric(tmp_gc$right_jump_snp_ref[i]) + as.numeric(sum(chr_len[1:(tmp_gc$chrID[i]-1)]))
}
}
tmp_gc <- tmp_gc[order(tmp_gc$right_jump_snp_ref),]
tmp_gc$Type <- rep("GC", nrow(tmp_gc))
if (strsplit(f, "_")[[1]][1] %in% c("tsaed", "la4", "da1")){
tmp_co <- read.csv(paste0("CO/",strsplit(f, "_")[[1]][1], "_germline_reads.csv"))
tmp_co$chr <- tmp_co$chromosome
tmp_co$right_jump_snp_ref <- tmp_co$break_position
} else {
tmp_co <- read.csv(paste0("CO/",f), sep  ="\t")
}
tmp_co$chrID <- as.numeric(unlist(strsplit(tmp_co$chr, "chr"))[-which(unlist(strsplit(tmp_co$chr, "chr"))=="")])
tmp_co <- na.omit(tmp_co) #removes chr 2A and 2B
if (sum(tmp_co$chrID==2)>0){
tmp_co <- tmp_co[-which(tmp_co$chrID==2),]
}
tmp_co <- tmp_co[order(tmp_co$chrID),]
for (i in 1:nrow(tmp_co)){
if (tmp_co$chrID[i]>1){
tmp_co$right_jump_snp_ref[i] <- as.numeric(tmp_co$right_jump_snp_ref[i]) + as.numeric(sum(chr_len[1:(tmp_co$chrID[i]-1)]))
}
}
tmp_co <- tmp_co[order(tmp_co$right_jump_snp_ref),]
tmp_co$Type <- rep("CO", nrow(tmp_co))
data[[strsplit(f, "_")[[1]][1]]] <- rbind(tmp_gc, tmp_co[,-which(colnames(tmp_co) %in% c("right_flank_ref", "left_flank_ref"))])
# create ~10 Mb bins => 300 parts per genome
bins <- seq(1,sum(chr_len), sum(chr_len)/300)
tmp_gc_bins <- c()
tmp_co_bins <- c()
for (j in 2:length(bins)){
tmp_gc_bins <- c(tmp_gc_bins, sum(tmp_gc$right_jump_snp_ref>=bins[j-1] & tmp_gc$right_jump_snp_ref<bins[j]))
tmp_co_bins <- c(tmp_co_bins, sum(tmp_co$right_jump_snp_ref>=bins[j-1] & tmp_co$right_jump_snp_ref<bins[j]))
}
data_bins[[strsplit(f, "_")[[1]][1]]] <- data.frame(GC = tmp_gc_bins, CO = tmp_co_bins)
data_bins_GC <- cbind(data_bins_GC,tmp_gc_bins)
data_bins_CO <- cbind(data_bins_CO,tmp_co_bins)
}
colnames(data_bins_GC) <- GC_names
colnames(data_bins_CO) <- GC_names
print("Test for overall differences in GC: ")
fisher.test(data_bins_GC, simulate.p.value = T)
print("Test for overall differences in CO: ")
fisher.test(data_bins_CO, simulate.p.value = T)
gc_pair_test <- list()
co_pair_test <- list()
printres <- matrix(NA,ncol = 3, nrow = 37)
ind <- 1
for (i in 1:(ncol(data_bins_GC)-1)){
for (j in (i+1):ncol(data_bins_GC)){
tname <- paste0(colnames(data_bins_GC)[i], "-", colnames(data_bins_GC)[j])
gc_pair_test[[tname]] <- fisher.test(data_bins_GC[,c(i,j)], simulate.p.value = T)
printres[ind,1:2] <- c(tname, gc_pair_test[[tname]]$p.value)
#  print(paste0(tname, " : p-value from Fisher Exact test for GCs: ", round(gc_pair_test[[tname]]$p.value,3)))
co_pair_test[[tname]] <- fisher.test(data_bins_CO[,c(i,j)], simulate.p.value = T)
printres[ind,3] <- co_pair_test[[tname]]$p.value
# print(paste0(tname, " : p-value from Fisher Exact test for COs: ", round(co_pair_test[[tname]]$p.value,3)))
ind <- ind+1
}
}
printres[,2] <- round(p.adjust(printres[,2], method = "BH"),3)
printres[,3] <- round(p.adjust(printres[,3], method = "BH"),3)
colnames(printres) <- c("", "GC", "CO")
printres <- na.omit(printres)
printres <- as.data.frame(printres)
printres
